class Solution {
public:
    int minOperations(vector<int>& nums, int k) {
        int n=nums.size();
        vector<int>rem(n);
        for(int i=0;i<n;i++){
            rem[i]=nums[i]%k;
        }
        int ans=INT_MAX;
        for(int x=0;x<k;x++){
            for(int y=0;y<k;y++){
                if(x==y) continue;
                int cost=0;
                for(int i=0;i<n;i++){
                    int target=(i%2==0)?x:y;
                    int r=rem[i];
                    int diff=abs(r-target);
                    cost+=min(diff,k-diff);
                }
                ans=min(ans,cost);
            }
        }
        return ans;
    }
};
