class Solution {
    bool safe(vector<vector<char>>& b,int r,int c,int x){
        for(int i=0;i<9;++i){
            if(b[r][i]==(char)(x+'0')) return false;
            if(b[i][c]==(char)(x+'0')) return false;
        }
        int sr=(r/3)*3;
        int sc=(c/3)*3;

        for(int i=sr;i<sr+3;++i){
            for(int j=sc;j<sc+3;++j){
                if(b[i][j]==(char)(x+'0')) return false;
            }
        }

        return true;
    }

    bool solve(vector<vector<char>>& b,int r,int c){
        if(c==9){
            r=r+1;
            c=0;
        }

        if(r==9) return true;

        if(b[r][c]!='.'){
            if(solve(b,r,c+1)) return true;
        }
        else{
            for(int i=1;i<=9;++i){
                if(safe(b,r,c,i)){
                    b[r][c]=(char)(i+'0');
                    if(solve(b,r,c+1)){
                        return true;
                    }
                    else{
                        b[r][c]='.';
                    }
                }
            }
        }

        return false;
    }

public:
    void solveSudoku(vector<vector<char>>& board) {
        solve(board,0,0);
        return;
    }
};
