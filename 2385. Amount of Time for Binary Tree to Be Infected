/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
    unordered_map<int, TreeNode*> parent;
    unordered_map<int, TreeNode*> nodes;

    void dfs(TreeNode* root, TreeNode* p) {
        if (!root) return;

        parent[root->val] = p;
        nodes[root->val] = root;

        dfs(root->left, root);
        dfs(root->right, root);
    }

public:
    int amountOfTime(TreeNode* root, int start) {

        if (!root) return 0;

        dfs(root, nullptr);

        queue<pair<TreeNode*, int>> q;
        q.push({nodes[start], 0});

        unordered_set<int> vis;
        vis.insert(start);

        int ans = 0;

        while (!q.empty()) {

            auto [node, time] = q.front();
            q.pop();

            ans = max(ans, time);

            // Left
            if (node->left && vis.count(node->left->val) == 0) {
                q.push({node->left, time + 1});
                vis.insert(node->left->val);
            }

            // Right
            if (node->right && vis.count(node->right->val) == 0) {
                q.push({node->right, time + 1});
                vis.insert(node->right->val);
            }

            // Parent
            if (parent[node->val] &&
                vis.count(parent[node->val]->val) == 0) {

                q.push({parent[node->val], time + 1});
                vis.insert(parent[node->val]->val);
            }
        }

        return ans;
    }
};
