class Solution {
public:
    vector<int> addToArrayForm(vector<int>& num, int k) {
        int n=num.size();
        int c=0;
        vector<int>ans;
        for(int i = n-1;i>=0;i--){
            int d = k % 10;
            int val = num[i] + d + c;
            c = val / 10;
            int sum = val %10;
            ans.push_back(sum);
            k/=10;


        }
        while(k!=0){
             int d = k % 10;
            int val = d + c;
            c = val / 10;
            int sum = val %10;
            ans.push_back(sum);
            k/=10;
        }
        if(c!=0){
            ans.push_back(c);
        }
        reverse(ans.begin(),ans.end());
        
        return ans;
    }
};
