class Solution {
public:
    int findGCD(vector<int>& arr) {
        int smallest=INT_MAX;
        int largest=INT_MIN;
        for(int i=0;i<arr.size();i++){
            if(arr[i]<smallest){
                smallest=arr[i];
            }
            if(arr[i]>largest){
                largest=arr[i];
            }
        }
int ans;
        for(int i=1;i<=largest;i++){
            if(smallest%i==0 && largest%i==0){
                ans=i;
            }
        }
        return ans;
    }
};
